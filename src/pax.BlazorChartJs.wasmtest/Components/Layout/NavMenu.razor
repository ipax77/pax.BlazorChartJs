            [
                new("chartjs-samples/line/interpolation", "Interpolation Modes", "Interpolation"),
                new("chartjs-samples/line/line", "Line Chart", "Line"),
                new("chartjs-samples/line/multi-axis", "Multi Axis Line Chart", "Multi Axis"),
                new("chartjs-samples/line/point-styling", "Point Styling", "Point Styling"),
                new("chartjs-samples/line/segments", "Line Segment Styling", "Segments"),
                new("chartjs-samples/line/stepped", "Stepped Line Charts", "Stepped"),
                new("chartjs-samples/line/styling", "Line Styling", "Styling"),
            ]),
        new(
            "other",
            "Other Charts",
            [
                new("chartjs-samples/other/bubble", "Bubble", "Bubble"),
                new("chartjs-samples/other/combo-bar-line", "Combo bar/line", "Combo bar/line"),
                new("chartjs-samples/other/doughnut", "Doughnut", "Doughnut"),
                new("chartjs-samples/other/multi-series-pie", "Multi Series Pie", "Multi Series Pie"),
                new("chartjs-samples/other/pie", "Pie", "Pie"),
                new("chartjs-samples/other/polar-area", "Polar area", "Polar area"),
                new("chartjs-samples/other/polar-area-center-labels", "Polar area centered point labels", "Polar centered labels"),
                new("chartjs-samples/other/radar", "Radar", "Radar"),
                new("chartjs-samples/other/radar-skip-points", "Radar skip points", "Radar skip points"),
                new("chartjs-samples/other/scatter", "Scatter", "Scatter"),
                new("chartjs-samples/other/scatter-multi-axis", "Scatter - Multi axis", "Scatter multi-axis"),
                new("chartjs-samples/other/stacked-bar-line", "Stacked bar/line", "Stacked bar/line"),
            ]),
        new(
            "area",
            "Area Charts",
            [
                new("chartjs-samples/area/line-boundaries", "Line Chart Boundaries", "Line Boundaries"),
                new("chartjs-samples/area/line-datasets", "Line Chart Datasets", "Line Datasets"),
                new("chartjs-samples/area/line-drawtime", "Line Chart drawTime", "Line drawTime"),
                new("chartjs-samples/area/line-stacked", "Line Chart Stacked", "Line Stacked"),
                new("chartjs-samples/area/radar-stacked", "Radar Chart Stacked", "Radar Stacked"),
            ]),
        new(
            "scales",
            "Scales",
            [
                new("chartjs-samples/scales/linear-min-max", "Linear Scale - Min-Max", "Linear Min-Max"),
                new("chartjs-samples/scales/linear-min-max-suggested", "Linear Scale - Suggested Min-Max", "Linear Suggested"),
                new("chartjs-samples/scales/linear-step-size", "Linear Scale - Step Size", "Linear Step Size"),
                new("chartjs-samples/scales/log", "Log Scale", "Log"),
                new("chartjs-samples/scales/stacked", "Stacked Linear / Category", "Stacked Linear / Category"),
                new("chartjs-samples/scales/time-line", "Time Scale", "Time"),
                new("chartjs-samples/scales/time-max-span", "Time Scale - Max Span", "Time Max Span"),
                new("chartjs-samples/scales/time-combo", "Time Scale - Combo Chart", "Time Combo"),
