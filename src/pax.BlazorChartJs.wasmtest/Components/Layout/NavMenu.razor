                new("chartjs-samples/scale-options/grid", "Grid Configuration", "Grid Configuration"),
                new("chartjs-samples/scale-options/ticks", "Tick Configuration", "Tick Configuration"),
                new("chartjs-samples/scale-options/titles", "Title Configuration", "Title Configuration"),
            ]),
        new(
            "legend",
