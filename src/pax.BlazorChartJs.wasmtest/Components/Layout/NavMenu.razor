        new(
            "scriptable",
            "Scriptable Options",
            [
                new("chartjs-samples/scriptable/bar", "Bar Chart", "Bar Chart"),
                new("chartjs-samples/scriptable/bubble", "Bubble Chart", "Bubble Chart"),
                new("chartjs-samples/scriptable/line", "Line Chart", "Line Chart"),
                new("chartjs-samples/scriptable/pie", "Pie Chart", "Pie Chart"),
                new("chartjs-samples/scriptable/polar", "Polar Area Chart", "Polar Area Chart"),
                new("chartjs-samples/scriptable/radar", "Radar Chart", "Radar Chart"),
            ]),
        new(
            "animations",
            "Animations",
            [
                new("chartjs-samples/animations/delay", "Delay", "Delay"),
