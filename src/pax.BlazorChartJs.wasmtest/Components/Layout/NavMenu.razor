@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">pax.BlazorChartJs</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <button type="button" class="nav-section-toggle px-3" @onclick="ToggleChartJsSamples" @onclick:stopPropagation="true" aria-expanded="@(!collapseChartJsSamples)">
            <span aria-hidden="true">@ChartJsSamplesCaret</span> Chart.js samples
        </button>
        <div class="nav-sample-group @ChartJsSamplesCssClass">
            @foreach (var section in ChartJsSampleSections)
            {
                var isExpanded = IsChartJsSampleSectionExpanded(section.Key);
                <button type="button" class="nav-subsection-toggle px-3" @onclick="@(() => ToggleChartJsSampleSection(section.Key))" @onclick:stopPropagation="true" aria-expanded="@isExpanded">
                    <span aria-hidden="true">@GetCaret(isExpanded)</span> @section.Title
                </button>
                <div class="@GetChartJsSampleSectionCssClass(section.Key)">
                    @foreach (var link in section.Links)
                    {
                        <div class="nav-item nav-item-nested px-3">
                            <NavLink class="nav-link" href="@link.Href" title="@link.Title">
                                @link.Text
                            </NavLink>
                        </div>
                    }
                </div>
            }
        </div>
        <button type="button" class="nav-section-toggle px-3" @onclick="ToggleLibrarySamples" @onclick:stopPropagation="true" aria-expanded="@(!collapseLibrarySamples)">
            <span aria-hidden="true">@LibrarySamplesCaret</span> Library samples
        </button>
        <div class="@LibrarySamplesCssClass">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="barchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> BarChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="linechart">
                    <span class="oi oi-plus" aria-hidden="true"></span> LineChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="multiplecharts">
                    <span class="oi oi-plus" aria-hidden="true"></span> MultipleCharts
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="eventschart">
                    <span class="oi oi-plus" aria-hidden="true"></span> EventsChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="scatterchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> ScatterChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="stackedchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> StackedChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="multiaxis">
                    <span class="oi oi-plus" aria-hidden="true"></span> MultiAxisChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="timeschart">
                    <span class="oi oi-plus" aria-hidden="true"></span> TimesChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="minchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> ReadmeChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="preloadpluginchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> PreloadPluginChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="datalabelschart">
                    <span class="oi oi-plus" aria-hidden="true"></span> DataLabelsChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="callbackchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> CallbackChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="scriptablepaddingchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> ScriptablePaddingChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="tooltipcallbackchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> TooltipCallbackChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="htmllegendchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> HtmlLegendChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="htmllegendpiechart">
                    <span class="oi oi-plus" aria-hidden="true"></span> HtmlLegendPieChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="udpatechart">
                    <span class="oi oi-plus" aria-hidden="true"></span> UpdateDatasetChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="synergysmoothchart">
                    <span class="oi oi-plus" aria-hidden="true"></span> SynergySmoothChart
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="disposechart">
                    <span class="oi oi-plus" aria-hidden="true"></span> DisposeChart
                </NavLink>
            </div>
        </div>
    </nav>
</div>

@code {
    private const string DefaultChartJsSampleSectionKey = "bar";

    private bool collapseNavMenu = true;
    private bool collapseLibrarySamples = true;
    private bool collapseChartJsSamples;
    private string activeChartJsSampleSectionKey = DefaultChartJsSampleSectionKey;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private string? LibrarySamplesCssClass => collapseLibrarySamples ? "nav-group-collapsed" : null;
    private string? ChartJsSamplesCssClass => collapseChartJsSamples ? "nav-group-collapsed" : null;
    private string LibrarySamplesCaret => GetCaret(!collapseLibrarySamples);
    private string ChartJsSamplesCaret => GetCaret(!collapseChartJsSamples);

    private static readonly ChartJsSampleSection[] ChartJsSampleSections =
    [
        new(
            DefaultChartJsSampleSectionKey,
            "Bar Charts",
            [
                new("chartjs-samples/bar/border-radius", "Bar Chart Border Radius", "Border Radius"),
