                new("chartjs-samples/legend/events", "Events", "Events"),
                new("chartjs-samples/legend/html", "HTML Legend", "HTML Legend"),
                new("chartjs-samples/legend/point-style", "Point Style", "Point Style"),
                new("chartjs-samples/legend/position", "Position", "Position"),
