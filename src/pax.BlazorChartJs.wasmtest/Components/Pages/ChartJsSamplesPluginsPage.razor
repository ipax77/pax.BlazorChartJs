@page "/chartjs-samples/plugins"
@page "/chartjs-samples/plugins/{SampleId}"
@using pax.BlazorChartJs.samplelib.ChartJsSamples.PluginSamples

<PageTitle>Chart.js Plugins</PageTitle>

<ChartJsPluginSamples SampleId="@ResolvedSampleId" @key="@ResolvedSampleId" />

@code {
    [Parameter]
    public string? SampleId { get; set; }

    private string ResolvedSampleId => string.IsNullOrWhiteSpace(SampleId) ? "chart-area-border" : SampleId;
}
