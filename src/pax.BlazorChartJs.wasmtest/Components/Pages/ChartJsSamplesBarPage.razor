@page "/chartjs-samples/bar"
@page "/chartjs-samples/bar/{SampleId}"
@using pax.BlazorChartJs.samplelib.ChartJsSamples.BarCharts

<PageTitle>Chart.js Bar Charts</PageTitle>

<ChartJsBarSamples SampleId="@ResolvedSampleId" />

@code {
    [Parameter]
    public string? SampleId { get; set; }

    private string ResolvedSampleId => string.IsNullOrWhiteSpace(SampleId) ? "vertical" : SampleId;
}
