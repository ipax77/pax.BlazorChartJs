@page "/chartjs-samples/advanced"
@page "/chartjs-samples/advanced/{SampleId}"
@using pax.BlazorChartJs.samplelib.ChartJsSamples.Advanced

<PageTitle>Chart.js Advanced</PageTitle>

<ChartJsAdvancedDataDecimationSample @key="ResolvedSampleId" />

@code {
    [Parameter]
    public string? SampleId { get; set; }

    private string ResolvedSampleId => string.IsNullOrWhiteSpace(SampleId) ? "data-decimation" : SampleId;
}
