@using pax.BlazorChartJs

<div class="btn-group">
    <button type="button" class="btn btn-primary" @onclick="ShowContentTooltip">Content</button>
    <button type="button" class="btn btn-primary" @onclick="ShowColorTooltip">Color</button>
    <button type="button" class="btn btn-primary" @onclick="ShowPointTooltip">Point</button>
    <button type="button" class="btn btn-primary" @onclick="ShowCustomDataTooltip">Custom Data</button>
    <button type="button" class="btn btn-primary" @onclick="ShowExternalTooltip">External</button>
</div>

<div class="chart-container w-75">
    <ChartComponent ChartJsConfig="chartJsConfig"></ChartComponent>
</div>

@code {
    private static readonly TooltipCallbacks ContentCallbacks = new()
        {
            Title = ChartJsFunction.FromName("formatTooltipContentTitle"),
            Label = ChartJsFunction.FromName("formatTooltipContentLabel"),
            Footer = ChartJsFunction.FromName("formatTooltipContentFooter")
        };

    private static readonly TooltipCallbacks ColorCallbacks = new()
        {
            Title = ChartJsFunction.FromName("formatTooltipColorTitle"),
            Label = ChartJsFunction.FromName("formatTooltipContentLabel"),
            LabelColor = ChartJsFunction.FromName("tooltipLabelColor"),
            LabelTextColor = ChartJsFunction.FromName("tooltipLabelTextColor"),
            Footer = ChartJsFunction.FromName("formatTooltipContentFooter")
        };

    private static readonly TooltipCallbacks PointCallbacks = new()
        {
            Title = ChartJsFunction.FromName("formatTooltipPointTitle"),
            Label = ChartJsFunction.FromName("formatTooltipContentLabel"),
            LabelPointStyle = ChartJsFunction.FromName("tooltipLabelPointStyle"),
            Footer = ChartJsFunction.FromName("formatTooltipContentFooter")
        };

    private static readonly TooltipCallbacks ExternalCallbacks = new()
        {
            Title = ChartJsFunction.FromName("formatTooltipExternalTitle"),
            Label = ChartJsFunction.FromName("formatTooltipContentLabel"),
            Footer = ChartJsFunction.FromName("formatTooltipContentFooter")
        };

    private static readonly TooltipCallbacks CustomDataCallbacks = new()
        {
            Title = ChartJsFunction.FromName("formatTooltipCustomDataTitle"),
            Label = ChartJsFunction.FromName("formatTooltipCustomDataLabel")
        };

    private static readonly ChartJsFunction ExternalTooltip = ChartJsFunction.FromName("renderExternalTooltip");

    private ChartJsConfig chartJsConfig = null!;

    protected override void OnInitialized()
    {
        chartJsConfig = new()
            {
                Type = ChartType.line,
                Data = new ChartJsData()
                {
                    Labels = ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
                    Datasets =
                    [
                        new CustomTooltipDataset()
                        {
                            Label = "Revenue",
                            Data = [18, 24, 20, 32, 28, 36],
                            TooltipPoints =
                            [
                                CreateTooltipPoint("Raynor", "Kerrigan", 0.32, 1.8, 51.4, 42),
                                CreateTooltipPoint("Raynor", "Artanis", 0.48, 2.4, 53.1, 55),
                                CreateTooltipPoint("Raynor", "Nova", 0.40, 2.0, 52.0, 38),
                                CreateTooltipPoint("Raynor", "Zagara", 0.64, 3.2, 56.8, 61),
                                CreateTooltipPoint("Raynor", "Stukov", 0.56, 2.8, 54.9, 44),
                                CreateTooltipPoint("Raynor", "Tychus", 0.72, 3.6, 58.2, 73)
                            ],
                            BorderColor = "#2563eb",
                            BackgroundColor = "rgba(37, 99, 235, 0.18)",
                            BorderWidth = 3,
                            PointRadius = 4,
                            PointHoverRadius = 6,
                            Tension = 0.3
                        },
                        new CustomTooltipDataset()
                        {
                            Label = "Pipeline",
                            Data = [12, 16, 22, 24, 31, 34],
                            TooltipPoints =
                            [
                                CreateTooltipPoint("Kerrigan", "Raynor", 0.24, 1.2, 49.6, 35),
                                CreateTooltipPoint("Kerrigan", "Artanis", 0.32, 1.6, 50.8, 47),
                                CreateTooltipPoint("Kerrigan", "Nova", 0.44, 2.2, 52.7, 58),
                                CreateTooltipPoint("Kerrigan", "Zagara", 0.48, 2.4, 53.5, 50),
                                CreateTooltipPoint("Kerrigan", "Stukov", 0.62, 3.1, 55.4, 69),
                                CreateTooltipPoint("Kerrigan", "Tychus", 0.68, 3.4, 57.0, 71)
                            ],
                            BorderColor = "#f97316",
                            BackgroundColor = "rgba(249, 115, 22, 0.16)",
                            BorderWidth = 3,
                            PointRadius = 4,
                            PointHoverRadius = 6,
                            Tension = 0.3
                        }
                    ]
                },
                Options = new ChartJsOptions()
                {
                    Responsive = true,
                    MaintainAspectRatio = true,
                    Interaction = new Interactions()
                    {
                        Mode = "index",
                        Intersect = false
                    },
                    Plugins = new Plugins()
                    {
                        Title = new Title()
                        {
                            Display = true,
                            Text = new IndexableOption<string>("Tooltip callback designs")
                        },
                        Tooltip = new Tooltip()
                        {
                            Enabled = true,
                            Callbacks = ContentCallbacks,
                            DisplayColors = true
                        }
                    },
                    Scales = new ChartJsOptionsScales()
                    {
                        Y = new LinearAxis()
                        {
                            BeginAtZero = true
                        }
                    }
                }
            };

        base.OnInitialized();
    }

    private void ShowContentTooltip()
    {
        ApplyTooltipDesign(ContentCallbacks, enabled: true, external: null, usePointStyle: false);
    }

    private void ShowColorTooltip()
    {
        ApplyTooltipDesign(ColorCallbacks, enabled: true, external: null, usePointStyle: false);
    }

    private void ShowPointTooltip()
    {
        ApplyTooltipDesign(PointCallbacks, enabled: true, external: null, usePointStyle: true);
    }

    private void ShowExternalTooltip()
    {
        ApplyTooltipDesign(
            ExternalCallbacks,
            enabled: false,
            external: ExternalTooltip,
            usePointStyle: false);
    }

    private void ShowCustomDataTooltip()
    {
        ApplyTooltipDesign(CustomDataCallbacks, enabled: true, external: null, usePointStyle: false);
    }

    private void ApplyTooltipDesign(
        TooltipCallbacks callbacks,
        bool enabled,
        ChartJsFunction? external,
        bool usePointStyle)
    {
        var tooltip = chartJsConfig.Options?.Plugins?.Tooltip;
        if (tooltip == null)
        {
            return;
        }

        tooltip.Enabled = enabled;
        tooltip.External = external;
        tooltip.Callbacks = callbacks;
        tooltip.UsePointStyle = usePointStyle;
        chartJsConfig.UpdateChartOptions();
    }

    private static CustomTooltipPoint CreateTooltipPoint(
        string commander,
        string teammate,
        double normalized,
        double avgGain,
        double winrate,
        int games)
    {
        return new()
        {
            Commander = commander,
            Teammate = teammate,
            Normalized = normalized,
            AvgGain = avgGain,
            Winrate = winrate,
            Games = games,
            Text = FormattableString.Invariant($"{commander} + {teammate}: AvgGain {avgGain:0.0}, Winrate {winrate:0.0}%, Games {games}, Normalized {normalized:0.00}")
        };
    }

    private sealed record CustomTooltipDataset : LineDataset
    {
        public IReadOnlyList<CustomTooltipPoint> TooltipPoints { get; init; } = [];
    }

    private sealed class CustomTooltipPoint
    {
        public string Commander { get; init; } = string.Empty;
        public string Teammate { get; init; } = string.Empty;
        public double Normalized { get; init; }
        public double AvgGain { get; init; }
        public double Winrate { get; init; }
        public int Games { get; init; }
        public string Text { get; init; } = string.Empty;
    }
}
