@namespace pax.BlazorChartJs.samplelib.ChartJsSamples.Advanced

@switch (ResolvedSampleId)
{
    case "derived-axis-type":
        <ChartJsAdvancedDerivedAxisTypeSample />
        break;
    case "derived-chart-type":
        <ChartJsAdvancedDerivedChartTypeSample />
        break;
    case "linear-gradient":
        <ChartJsAdvancedLinearGradientSample />
        break;
    default:
        <ChartJsAdvancedDataDecimationSample />
        break;
}

@code {
    [Parameter]
    public string SampleId { get; set; } = "data-decimation";

    private string ResolvedSampleId => SampleId switch
    {
        "data-decimation" or "derived-axis-type" or "derived-chart-type" or "linear-gradient" => SampleId,
        _ => "data-decimation",
    };
}
